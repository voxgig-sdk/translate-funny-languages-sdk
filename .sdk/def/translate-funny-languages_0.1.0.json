{
  "openapi": "3.0.3",
  "info": {
    "title": "Translate Funny Languages",
    "description": "Translate english to funny languages like Morse Code, Sith or Valyrian",
    "version": "1.0.0",
    "contact": {
      "url": "https://api.funtranslations.com/"
    }
  },
  "servers": [
    {
      "url": "https://api.funtranslations.com",
      "description": "Production server"
    }
  ],
  "paths": {
    "/translate/{translator}.json": {
      "get": {
        "summary": "Translate text to funny language",
        "description": "Translates English text to various funny languages like Morse Code, Sith, Valyrian, and others",
        "operationId": "translateText",
        "parameters": [
          {
            "name": "translator",
            "in": "path",
            "required": true,
            "description": "The translator/language to use (e.g., morse, sith, valyrian, yoda, shakespeare, minion, pirate, etc.)",
            "schema": {
              "type": "string",
              "enum": [
                "morse",
                "sith",
                "valyrian",
                "yoda",
                "shakespeare",
                "minion",
                "pirate",
                "dothraki",
                "klingon",
                "sindarin",
                "quenya",
                "vulcan",
                "huttese",
                "dolan"
              ]
            }
          },
          {
            "name": "text",
            "in": "query",
            "required": true,
            "description": "The English text to translate",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful translation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer",
                          "description": "Number of translations performed"
                        }
                      }
                    },
                    "contents": {
                      "type": "object",
                      "properties": {
                        "translated": {
                          "type": "string",
                          "description": "The translated text"
                        },
                        "text": {
                          "type": "string",
                          "description": "The original text"
                        },
                        "translation": {
                          "type": "string",
                          "description": "The translation type/language used"
                        }
                      }
                    }
                  }
                },
                "example": {
                  "success": {
                    "total": 1
                  },
                  "contents": {
                    "translated": ".... . .-.. .-.. ---",
                    "text": "hello",
                    "translation": "morse"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing or invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "integer"
                        },
                        "message": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "integer"
                        },
                        "message": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Translate text to funny language (POST)",
        "description": "Translates English text to various funny languages using POST method",
        "operationId": "translateTextPost",
        "parameters": [
          {
            "name": "translator",
            "in": "path",
            "required": true,
            "description": "The translator/language to use (e.g., morse, sith, valyrian, yoda, shakespeare, minion, pirate, etc.)",
            "schema": {
              "type": "string",
              "enum": [
                "morse",
                "sith",
                "valyrian",
                "yoda",
                "shakespeare",
                "minion",
                "pirate",
                "dothraki",
                "klingon",
                "sindarin",
                "quenya",
                "vulcan",
                "huttese",
                "dolan"
              ]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "The English text to translate"
                  }
                },
                "required": [
                  "text"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful translation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer",
                          "description": "Number of translations performed"
                        }
                      }
                    },
                    "contents": {
                      "type": "object",
                      "properties": {
                        "translated": {
                          "type": "string",
                          "description": "The translated text"
                        },
                        "text": {
                          "type": "string",
                          "description": "The original text"
                        },
                        "translation": {
                          "type": "string",
                          "description": "The translation type/language used"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing or invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "integer"
                        },
                        "message": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "integer"
                        },
                        "message": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TranslationResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "object",
            "properties": {
              "total": {
                "type": "integer"
              }
            }
          },
          "contents": {
            "type": "object",
            "properties": {
              "translated": {
                "type": "string"
              },
              "text": {
                "type": "string"
              },
              "translation": {
                "type": "string"
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "integer"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
